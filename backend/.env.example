# Copy file nay thanh .env roi sua cho may cua ban
# MySQL/MariaDB tren XAMPP (mac dinh: root, khong mat khau, cong 3306)
DATABASE_URL="mysql://root:@localhost:3306/hoangnha_fashion"
JWT_SECRET="doi-chuoi-nay-thanh-chuoi-ngau-nhien-dai"
PORT=4000

# ============ SEPAY - Thanh toan chuyen khoan ngan hang ============
# 1. Dang ky mien phi tai https://my.sepay.vn va lien ket tai khoan ngan hang
# 2. Vao menu Webhooks -> Them webhook:
#    - URL: https://<ngrok-cua-ban>.ngrok-free.app/api/sepay/webhook
#    - Su kien: Co tien vao
#    - Bao mat: API Key -> dat chuoi ngau nhien, dan vao SEPAY_API_KEY duoi day
# 3. Chay ngrok de SePay goi duoc vao may ban:  ngrok http 4000

# So tai khoan nhan tien
SEPAY_ACCOUNT=""
# Ma ngan hang, danh sach: https://qr.sepay.vn/banks.json (vd: MBBank, Vietcombank, ACB)
SEPAY_BANK="MBBank"
# API Key trung voi cai da dat tren my.sepay.vn
SEPAY_API_KEY=""
# QR het han sau bao nhieu phut
SEPAY_EXPIRE_MINUTES=15
# Bat nut "Toi da chuyen khoan" de test khi chua co tai khoan SePay that.
# LUON de false khi chay that!
SEPAY_ALLOW_SIMULATE="true"
