// ============================================================
// Hoàng Nha Fashion — Schema 15 bảng (bản rút gọn, đủ cho shop bình thường)
// Ánh xạ 1-1 với ERD tại docs/erd.md
// MySQL/MariaDB trên XAMPP (root, không mật khẩu)
// Quay lại SQLite: provider = "sqlite" + DATABASE_URL="file:./dev.db"
//
// Đã bỏ so với bản 32 bảng: điểm thưởng, tag, bộ sưu tập, chiến dịch,
// lượt xem, nhật ký kho, đổi/trả, bảng lượt-dùng-voucher, ảnh đánh giá,
// bài viết, cấu hình. Vận đơn gộp vào Order; wishlist chuyển sang client.
// GIỮ LẠI: tích hợp thanh toán SePay (Payment + SepayWebhookLog).
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/* ============ 1. NGƯỜI DÙNG ============ */

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  passwordHash  String
  phone         String?
  avatar        String?
  gender        String?
  birthday      String?
  role          String         @default("CUSTOMER") // CUSTOMER | ADMIN
  createdAt     DateTime       @default(now())
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  cartItems     CartItem[]
  notifications Notification[]
}

/* ============ 2. SỔ ĐỊA CHỈ ============ */

model Address {
  id        Int     @id @default(autoincrement())
  userId    Int
  label     String
  name      String
  phone     String
  street    String
  ward      String
  district  String
  city      String
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/* ============ 3. DANH MỤC ============ */

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  image    String    @db.Text
  products Product[]
}

/* ============ 4. SẢN PHẨM ============ */

model Product {
  id           Int            @id @default(autoincrement())
  categoryId   Int
  name         String
  slug         String         @unique
  description  String         @db.Text
  price        Int
  oldPrice     Int? // giá gạch ngang khi sale
  brand        String
  material     String
  rating       Float          @default(0) // trung bình đánh giá (phi chuẩn hóa)
  reviewCount  Int            @default(0)
  sold         Int            @default(0)
  // Cờ phân loại — thay cho bảng Collection/Campaign/Tag. Lọc "mới/bán chạy/sale"
  // ngay trên bảng này, đủ cho một shop bình thường, không cần bảng phụ.
  isNew        Boolean        @default(false)
  isBestSeller Boolean        @default(false)
  isTrending   Boolean        @default(false)
  flashSale    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  category     Category       @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  variants     Variant[]
  reviews      Review[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
}

/* ============ 5. ẢNH SẢN PHẨM ============ */

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String  @db.Text
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/* ============ 6. BIẾN THỂ (màu × size × tồn kho) ============ */

model Variant {
  id        Int     @id @default(autoincrement())
  productId Int
  color     String
  colorHex  String
  size      String
  stock     Int     @default(0)
  // Giá riêng cho biến thể (size XXL / màu limited đắt hơn). NULL = dùng giá sản phẩm.
  price     Int?
  oldPrice  Int?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color, size])
}

/* ============ 7. GIỎ HÀNG ============ */

model CartItem {
  id        Int     @id @default(autoincrement())
  userId    Int
  productId Int
  color     String
  size      String
  quantity  Int     @default(1)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, color, size])
}

/* ============ 8. ĐƠN HÀNG (gộp thông tin vận chuyển) ============ */

model Order {
  id             String      @id // HN-yymmdd-xxxx
  userId         Int
  voucherId      Int?
  status         String      @default("pending") // pending|confirmed|shipping|delivered|cancelled
  paymentMethod  String // cod | qr
  shippingMethod String      @default("standard")
  shippingFee    Int         @default(0)
  discount       Int         @default(0)
  subtotal       Int
  total          Int
  receiverName   String
  receiverPhone  String
  receiverEmail  String
  addressText    String      @db.Text
  note           String?     @db.Text
  // Vận đơn gộp thẳng vào đây (trước là bảng Shipment riêng) — quan hệ 1-1,
  // gộp lại đỡ một bảng mà không mất thông tin gì.
  shipCarrier    String? // đơn vị vận chuyển, vd "GHN Express"
  trackingCode   String? // mã vận đơn
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime    @default(now())
  user           User        @relation(fields: [userId], references: [id])
  voucher        Voucher?    @relation(fields: [voucherId], references: [id])
  items          OrderItem[]
  payment        Payment?
}

/* ============ 9. DÒNG ĐƠN HÀNG (snapshot giá) ============ */

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   String
  productId Int
  name      String // snapshot tên lúc mua
  price     Int // snapshot giá lúc mua
  quantity  Int
  color     String
  size      String
  image     String  @db.Text
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

/* ============ 10. THANH TOÁN (SePay / QR) ============ */

model Payment {
  id              Int       @id @default(autoincrement())
  orderId         String    @unique
  method          String // cod | qr
  status          String    @default("pending") // pending|paid|failed|refunded
  amount          Int
  transactionCode String?
  // Mã ghi trong nội dung chuyển khoản — NGẪU NHIÊN, không đoán được,
  // để kẻ xấu không claim đơn người khác. SePay đọc ở trường `code`.
  payCode         String?   @unique
  expiresAt       DateTime? // hạn QR (15 phút)
  paidAt          DateTime?
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

/* ============ 11. NHẬT KÝ WEBHOOK SEPAY (chống trùng) ============ */
// transactionId UNIQUE là khóa chống trùng: SePay retry tới 7 lần khi lỗi,
// cùng một giao dịch có thể gửi nhiều lần — không có bảng này thì đơn bị
// cộng tiền / gửi thông báo lặp.

model SepayWebhookLog {
  id            Int      @id @default(autoincrement())
  transactionId BigInt   @unique
  gateway       String?
  payCode       String?
  amount        Int      @default(0)
  transferType  String? // in | out
  referenceCode String?
  matched       Boolean  @default(false)
  rawBody       String   @db.Text
  createdAt     DateTime @default(now())
}

/* ============ 12. VOUCHER ============ */
// "Mỗi khách 1 lần / mã" không cần bảng lượt-dùng riêng: kiểm bằng truy vấn
// Order(userId, voucherId, status != cancelled) khi đặt hàng.

model Voucher {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  type        String // percent | fixed | freeship
  value       Int
  description String
  minOrder    Int      @default(0)
  expiry      DateTime
  usageLimit  Int      @default(1000)
  usedCount   Int      @default(0)
  orders      Order[]
}

/* ============ 13. ĐÁNH GIÁ ============ */

model Review {
  id         Int      @id @default(autoincrement())
  userId     Int
  productId  Int
  rating     Int
  title      String?
  content    String   @db.Text
  adminReply String?  @db.Text // phản hồi của shop
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/* ============ 14. THÔNG BÁO ============ */

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  content   String   @db.Text
  type      String   @default("system") // order | promo | system
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/* ============ 15. BANNER (hero trang chủ) ============ */

model Banner {
  id        Int     @id @default(autoincrement())
  eyebrow   String
  title     String
  subtitle  String  @db.Text
  image     String  @db.Text
  cta       String  @default("Khám phá ngay")
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}
